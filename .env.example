# =============================================================================
# CDC — plantilla UNICA de entorno (compartida por back+front+infra).
# Copiar a .env (chmod 600) y completar los valores <changeme>.
# Alineada con platform/docs/PLATFORM_INTEGRATION_SPEC.md §10.
#
# CDC usa autenticacion por JWT (no BFF OIDC). Si en el futuro se migra a BFF
# Keycloak, reemplazar las JWT_* por el bloque OIDC_* (ver est-infra/.env.example).
#
# Este archivo sirve tanto para prd remoto como para dev local.
# En dev, docker-compose.override.yml pisa URLs/cookies para localhost.
# =============================================================================

# ── Stack ──
CDC_ENV=prd                          # prd | dev. Decide project name y etiquetas.
NODE_ENV=production                  # production (make up) | development (make up-dev)
LOG_LEVEL=info
PORT=4000                            # puerto interno del back

# ── SQL Server (DBCDC en el SQL compartido 192.168.8.24) ────────────────────
DB_HOST=192.168.8.24
DB_PORT=1433
DB_NAME=DBCDC
DB_USER=<changeme>
DB_PASSWORD=<changeme>
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# ── JWT (auth propia) ────────────────────────────────────────────────────────
# Minimo 32 bytes hex. Generar: openssl rand -hex 32
JWT_SECRET=<changeme-hex-64>
JWT_EXPIRES_IN=8h
