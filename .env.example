# Node
NODE_ENV=production

# Back
PORT=4000

# DB (conexion remota usada por cdc-back)
DB_HOST=
DB_PORT=1433
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# ── OIDC (Keycloak BFF) ─────────────────────────────────────────────
# Issuer publico (claim 'iss' del id_token).
OIDC_ISSUER_URL=http://<host-publico>:8080/realms/CDCRealm
# Discovery interno desde dentro del docker network platform_identity.
OIDC_DISCOVERY_URL=http://keycloak:8080/realms/CDCRealm/.well-known/openid-configuration
OIDC_CLIENT_ID=cdc-back
# Hex 64 chars. Mismo valor que CDC_BACK_CLIENT_SECRET en platform/.env.
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://<host-publico>:81/api/v1/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://<host-publico>:81/login
OIDC_SCOPES=openid profile email
OIDC_REQUIRED_ROLE=cdc-user

# ── Sesion BFF ──────────────────────────────────────────────────────
SESSION_COOKIE_NAME=cdc.sid
# openssl rand -hex 32
SESSION_COOKIE_SECRET=
# true en QA/prod (con HTTPS terminado en el router). false solo dev local.
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=strict
SESSION_TTL_SECONDS=28800

# ── Redis (sesion store, DB 3 reservada para CDC) ───────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=3
