# =============================================================================
# CDC — plantilla UNICA de entorno (compartida por back+infra).
# Copiar a .env (chmod 600) y completar los valores <changeme>.
# Alineada con platform/docs/AUTH_STANDARD.md.
#
# Esquema de auth: BFF OIDC contra Keycloak (no password local).
# =============================================================================

# ── Stack ──
CDC_ENV=prd                          # prd | dev. Decide project name y etiquetas.
NODE_ENV=production                  # production | development
LOG_LEVEL=info
PORT=4000                            # puerto interno del back

# ── SQL Server (DBCDC en el SQL compartido) ────────────────────────────────
DB_HOST=192.168.8.24
DB_PORT=1433
DB_NAME=DBCDC
DB_USER=<changeme>
DB_PASSWORD=<changeme>
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# ── OIDC (BFF — cliente `cdc-back` en realm CDCRealm) ──────────────────────
# Las redirect URIs deben coincidir EXACTAS con las registradas en
# platform/keycloak/import/cdc-realm.json.
OIDC_ISSUER_URL=http://192.168.18.18:8080/realms/CDCRealm
OIDC_DISCOVERY_URL=http://keycloak:8080/realms/CDCRealm/.well-known/openid-configuration
OIDC_CLIENT_ID=cdc-back
OIDC_CLIENT_SECRET=<changeme>
OIDC_REDIRECT_URI=http://192.168.18.18:81/api/v1/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://192.168.18.18:81/login
OIDC_SCOPES=openid profile email
OIDC_REQUIRED_ROLE=cdc-user

# ── Sesion BFF (Redis — DB 3 reservada a CDC, AUTH_STANDARD §4) ────────────
# Password URL-encoded si contiene caracteres especiales (+, =, /).
SESSION_REDIS_URL=redis://:<REDIS_PASSWORD_URL_ENCODED>@redis:6379/3
SESSION_COOKIE_NAME=cdc.sid
SESSION_COOKIE_SECRET=<changeme-hex-64>   # openssl rand -hex 32
SESSION_COOKIE_SECURE=true                # false solo si el router sirve HTTP plano (deuda visible)
SESSION_COOKIE_SAMESITE=strict
SESSION_TTL_SECONDS=28800                 # 8h (rolling)
